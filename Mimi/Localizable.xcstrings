    "Sit nearby at your cat's level without blocking an exit." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asseyez-vous près de lui, à sa hauteur, sans bloquer une sortie."
