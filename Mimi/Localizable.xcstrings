          "stringUnit" : {
            "state" : "translated",
            "value" : "Que faut-il faire régulièrement avec les jouets utilisés sans surveillance ?"
          }
        }
      }
    },
    "Routine inspection catches wear before a loose piece, stuffing, bell, or sharp edge becomes a hazard." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une inspection régulière repère l’usure avant qu’une pièce détachée, du rembourrage, une clochette ou un bord tranchant ne devienne dangereux."
          }
