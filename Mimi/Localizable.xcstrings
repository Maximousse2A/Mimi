    },
    "Why do cats scratch surfaces?" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pourquoi les chats griffent-ils les surfaces ?"
          }
        }
      }
    },
    "Scratching is normal communication and body care. Suitable scratchers make the behavior easier to direct." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Griffer est un comportement normal de communication et d’entretien du corps. Des griffoirs adaptés permettent de mieux l’orienter."
          }
        }
      }
    },
    "Only to damage furniture" : {
      "extractionState" : "manual",
