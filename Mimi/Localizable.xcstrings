    "Which change should not be dismissed as 'just getting old'?" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quel changement ne doit pas être attribué simplement au vieillissement ?"
          }
        }
      }
    },
    "Mobility and routine changes may reflect pain or illness. Senior cats benefit from early assessment and practical support." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des changements de mobilité ou de routine peuvent refléter une douleur ou une maladie. Les chats âgés bénéficient d’une évaluation précoce et d’aménagements pratiques."
          }
        }
      }
    },
    "New difficulty jumping, grooming, eating, or using the litter box" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
