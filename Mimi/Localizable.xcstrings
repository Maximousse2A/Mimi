    "What is useful to record when a cat starts limping?" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qu’est-il utile de noter lorsqu’un chat commence à boiter ?"
          }
        }
      }
    },
    "Timing, pattern, and video can help a veterinary team assess movement that may look different in the clinic." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le moment d’apparition, l’évolution et une vidéo peuvent aider l’équipe vétérinaire à évaluer un mouvement parfois différent en clinique."
          }
        }
      }
    },
    "Only the cat's mood" : {
