    "Use brief visual access and supervised meetings only when both cats can stay relatively relaxed at the previous stage." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez de brefs contacts visuels et des rencontres supervisées seulement quand les deux chats restent relativement détendus à l’étape précédente."
          }
        }
      }
    },
    "Use clean bowls in a quiet spot away from the litter box. In multi-cat homes, separate feeding areas can reduce pressure around food." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez des gamelles propres dans un endroit calme, loin de la litière. Dans les foyers avec plusieurs chats, séparer les zones de repas peut réduire la pression autour de la nourriture."
          }
        }
      }
    },
    "Use fingers as prey" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utiliser les doigts comme proies"
          }
        }
      }
    },
    "Use gentle contact" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utiliser un contact doux"
          }
        }
      }
    },
    "Use gentle fluttering and short landings rather than keeping a toy constantly out of reach." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez des mouvements flottants doux et de courts atterrissages plutôt que de garder le jouet toujours hors d’atteinte."
          }
        }
      }
    },
    "Use play to learn their patterns" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utiliser le jeu pour comprendre ses habitudes"
          }
        }
      }
    },
    "Use slower toys near the floor and let the game come to your cat instead of demanding long chases." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez des jouets plus lents près du sol et laissez le jeu venir à votre chat au lieu d’exiger de longues poursuites."
          }
        }
      }
    },
    "Use small rewards for carrier practice, grooming cooperation, calm greetings, or another behavior you want to make easier." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez de petites récompenses pour l’habituation à la caisse, la coopération au toilettage, les salutations calmes ou tout comportement que vous voulez faciliter."
          }
        }
      }
    },
    "Use the four-clue pause" : {
      "extractionState" : "manual",
