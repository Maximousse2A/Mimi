    "A newly arrived cat stays in a hiding place. What is the most helpful response?" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un chat nouvellement arrivé reste caché. Quelle réaction est la plus utile ?"
