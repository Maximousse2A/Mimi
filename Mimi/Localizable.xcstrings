      }
    },
    "A protected retreat helps an overwhelmed cat regulate stress and begin exploring at their own pace." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un refuge protégé aide un chat dépassé à réguler son stress et à commencer à explorer à son rythme."
