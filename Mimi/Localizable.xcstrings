          }
        }
      }
    },
    "Pulled-back whiskers can join other facial tension signals. Check the ears, eyes, posture, and context." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des moustaches tirées vers l’arrière peuvent accompagner d’autres signes de tension faciale. Observez les oreilles, les yeux, la posture et le contexte."
          }
