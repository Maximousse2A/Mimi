    },
    "It improves litter habits" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela améliore les habitudes de litière"
          }
        }
      }
    },
    "It proves the blocked cat is shy" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela prouve que le chat bloqué est timide"
          }
        }
      }
    },
    "What is a good sign that a play session has lasted long enough?" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quel signe indique qu’une séance de jeu a suffisamment duré ?"
          }
        }
      }
    },
    "Short, satisfying sessions can be better than pushing past the cat's interest or physical comfort." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des séances courtes et satisfaisantes peuvent être préférables à poursuivre au-delà de l’intérêt ou du confort physique du chat."
          }
        }
      }
    },
    "The human is bored" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’humain s’ennuie"
          }
        }
      }
    },
    "The cat disengages, slows down, or settles" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le chat se désengage, ralentit ou se pose"
