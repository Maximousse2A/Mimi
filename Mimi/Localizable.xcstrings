          "stringUnit" : {
            "state" : "translated",
            "value" : "Se demander ce qui vient de se passer"
          }
        }
      }
    },
    "Ask your veterinarian about new stiffness, reluctance to jump, weakness, pain, or a sudden drop in activity." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parlez à votre vétérinaire de toute nouvelle raideur, réticence à sauter, faiblesse, douleur ou baisse soudaine d’activité."
          }
        }
      }
    },
