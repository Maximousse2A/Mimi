          "stringUnit" : {
            "state" : "translated",
            "value" : "Utiliser la pause aux quatre indices"
          }
        }
      }
    },
    "Use the photo as a prompt to check visible clues yourself: tail, ears, posture, eyes, and context." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez la photo comme aide pour vérifier vous-même les indices visibles : queue, oreilles, posture, yeux et contexte."
