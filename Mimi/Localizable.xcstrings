    "20 practical mini lessons you can use today." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "20 mini-leçons pratiques à utiliser dès aujourd’hui."
