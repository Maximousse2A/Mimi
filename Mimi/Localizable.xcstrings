    },
    "Sleepy" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Somnolent"
          }
        }
      }
    },
    "Slide or dart a toy along the floor and around corners to imitate small ground prey." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites glisser ou filer un jouet au sol et autour des coins pour imiter une petite proie terrestre."
          }
        }
      }
    },
    "Slow down when tension rises" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ralentir quand la tension monte"
          }
        }
      }
    },
    "Slow stages give both cats time to adjust." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des étapes lentes donnent aux deux chats le temps de s’adapter."
          }
        }
      }
    },
    "Slower reactions, grooming, walking away, or a twitching tail can mean the session is done. Stop while play still feels successful." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des réactions plus lentes, la toilette, le départ ou une queue qui tressaille peuvent signifier que la séance est terminée. Arrêtez pendant que le jeu reste une réussite."
          }
        }
      }
    },
    "Small behavior changes can appear before obvious distress." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De petits changements de comportement peuvent apparaître avant une détresse évidente."
          }
        }
      }
    },
    "Small observations make drinking changes easier to catch." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De petites observations rendent les changements de boisson plus faciles à repérer."
          }
        }
      }
    },
    "Small, purposeful rewards support training and care without crowding out balanced meals." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De petites récompenses utiles soutiennent l'apprentissage et les soins sans remplacer les repas équilibrés."
