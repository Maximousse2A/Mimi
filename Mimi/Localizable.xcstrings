            "state" : "translated",
            "value" : "doux"
          }
        }
      }
    },
    "Soft eyes and neutral ears often belong to a settled moment. Ears turned sideways or back, wide pupils, and tense whiskers suggest you should slow down and give space." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des yeux doux et des oreilles neutres accompagnent souvent un moment calme. Des oreilles tournées sur le côté ou vers l’arrière, des pupilles larges et des moustaches tendues indiquent plutôt qu’il faut ralentir et laisser de l’espace."
          }
        }
      }
    },
    "Soft purr" : {
      "extractionState" : "manual",
