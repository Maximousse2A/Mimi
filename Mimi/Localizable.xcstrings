      }
    },
    "Inside the litter area" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dans l’espace des litières"
          }
        }
      }
    },
    "Where another cat can block it" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Là où un autre chat peut en bloquer l’accès"
          }
        }
      }
    },
    "Your cat suddenly stops eating. What is the best response?" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre chat cesse soudainement de manger. Quelle est la meilleure réaction ?"
          }
        }
      }
    },
    "A sudden loss of appetite can become serious quickly in cats. Prompt veterinary guidance is the safest next step." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une perte soudaine d’appétit peut rapidement devenir grave chez le chat. Demander rapidement un avis vétérinaire est la conduite la plus sûre."
          }
        }
      }
    },
    "Wait several days without checking" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Attendre plusieurs jours sans vérifier"
          }
        }
      }
    },
    "Offer only treats" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proposer uniquement des friandises"
          }
        }
      }
    },
    "Contact a veterinary professional promptly" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contacter rapidement un professionnel vétérinaire"
          }
        }
      }
    },
    "Force food into their mouth" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forcer de la nourriture dans sa bouche"
          }
        }
      }
    },
    "What is the most reliable way to notice a gradual weight change?" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quel est le moyen le plus fiable de remarquer une évolution progressive du poids ?"
          }
        }
      }
    },
    "Regular measurements and body-condition checks reveal trends that can be hard to see day to day." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des pesées régulières et le suivi de la condition corporelle révèlent des tendances difficiles à voir au quotidien."
          }
        }
      }
    },
    "Judge from fur fluffiness" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se fier au volume du pelage"
