      }
    },
    "The toy breaks" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le jouet se casse"
          }
        }
      }
    },
    "The cat is forced to keep chasing" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le chat est forcé de continuer à poursuivre"
          }
        }
      }
    },
    "How can laser-pointer play be made less frustrating?" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comment rendre le jeu au pointeur laser moins frustrant ?"
          }
        }
      }
    },
    "A tangible catch gives the hunting sequence a clear ending instead of leaving the cat chasing something impossible to capture." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une prise tangible donne une fin claire à la séquence de chasse au lieu de laisser le chat poursuivre quelque chose d’impossible à attraper."
          }
        }
      }
    },
    "Move it into the cat's eyes" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le diriger vers les yeux du chat"
          }
        }
      }
    },
    "End while the cat is still searching" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arrêter pendant que le chat cherche encore"
          }
        }
      }
    },
    "Finish with a toy or treat the cat can physically catch" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Terminer avec un jouet ou une friandise que le chat peut réellement attraper"
