    },
    "A relaxed cat kneading a soft blanket is commonly showing what?" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un chat détendu qui pétrit une couverture douce exprime généralement quoi ?"
          }
        }
      }
    },
    "Kneading is a common comfort behavior carried from kittenhood, especially when the body is loose and settled." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le pétrissage est un comportement de réconfort courant hérité de l’enfance, surtout lorsque le corps est souple et détendu."
