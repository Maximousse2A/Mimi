          }
        }
      }
    },
    "Showing the belly can signal trust or relaxation, but it is not automatic permission to touch." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Montrer son ventre peut signaler de la confiance ou de la détente, mais ce n’est pas une autorisation automatique de le toucher."
          }
        }
      }
    },
