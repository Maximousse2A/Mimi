            "value" : "Avatar"
          }
        }
      }
    },
    "Avoid forcing sudden twists, very high jumps, or sprints across slippery floors and clutter." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Évitez d’imposer des torsions soudaines, de très hauts sauts ou des sprints sur des sols glissants ou encombrés."
          }
        }
      }
    },
    "Avoid universal translations" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
