          "stringUnit" : {
            "state" : "translated",
            "value" : "Des oreilles aplaties et une posture accroupie tendue indiquent généralement quoi ?"
          }
        }
      }
    },
    "Flattened ears with a tense, lowered body often mean the cat needs more distance and less pressure." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
