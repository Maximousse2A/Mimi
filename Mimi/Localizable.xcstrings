          "stringUnit" : {
            "state" : "translated",
            "value" : "L’utiliser dans des escaliers glissants"
          }
        }
      }
    },
    "Why is it better not to teach a kitten that hands are prey?" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pourquoi vaut-il mieux ne pas apprendre à un chaton que les mains sont des proies ?"
          }
        }
      }
    },
    "Toys create a clear target for hunting behavior and help keep human skin outside the game." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les jouets offrent une cible claire au comportement de chasse et permettent de garder la peau humaine hors du jeu."
          }
        }
      }
    },
    "Hands move too slowly" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les mains bougent trop lentement"
          }
        }
