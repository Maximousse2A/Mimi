    "What should you do before giving a cat any human medication?" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Que devez-vous faire avant de donner un médicament humain à un chat ?"
          }
        }
      }
    },
    "Many common human medicines are dangerous to cats. Only give medication under specific veterinary direction." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De nombreux médicaments humains courants sont dangereux pour les chats. Ne donnez un médicament que sur indication vétérinaire précise."
          }
        }
      }
    },
    "Use half the human dose" : {
