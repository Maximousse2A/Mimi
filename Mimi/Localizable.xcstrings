            "state" : "translated",
            "value" : "Pourquoi une simple boîte en carton peut-elle être un enrichissement précieux ?"
          }
        }
      }
    },
    "A safe box can support choice, concealment, play, and observation at very little cost." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une boîte sûre peut favoriser le choix, la cachette, le jeu et l’observation à très faible coût."
