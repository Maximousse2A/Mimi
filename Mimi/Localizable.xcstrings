    "Cats do not need to fight openly for one cat to feel blocked, rushed, or unsafe around food." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les chats n’ont pas besoin de se battre ouvertement pour que l’un d’eux se sente bloqué, pressé ou en insécurité autour de la nourriture."
          }
        }
      }
    },
    "Change every bowl daily" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Changer chaque gamelle tous les jours"
          }
        }
      }
    },
    "Change one part of the setup and compare the next meal." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modifiez un élément de l’installation et comparez avec le repas suivant."
          }
        }
      }
    },
    "Change them anytime" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Modifiez-les à tout moment"
          }
        }
      }
    },
    "Changes from normal, especially with appetite, breathing, litter-box, or energy shifts, deserve attention." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les changements par rapport à la normale, surtout avec l'appétit, la respiration, la litière ou l'énergie, méritent de l'attention."
          }
        }
      }
    },
    "Changes in eating, grooming, sleep, play, scratching, or litter-box use can appear alongside stress." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des changements d’alimentation, de toilette, de sommeil, de jeu, de griffades ou de litière peuvent accompagner le stress."
          }
        }
      }
    },
    "Changes in frequency, amount, posture, location, or comfort can be more useful than the occasional accident alone." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les changements de fréquence, de quantité, de posture, de lieu ou de confort peuvent être plus utiles qu’un accident isolé."
          }
        }
      }
    },
    "Changes matter more than any single vocalization." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les changements comptent plus qu’une vocalisation isolée."
          }
        }
      }
    },
    "Chase forever without catching" : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poursuivre sans jamais attraper"
          }
        }
      }
    },
    "Chase mode is active. Please provide entertainment with proper dramatic flair." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mode poursuite activé. Merci de fournir un divertissement avec le sens du spectacle."
          }
        }
      }
    },
    "Check for loose pieces, frayed strings, sharp edges, or damage before and after play." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vérifiez les pièces lâches, les ficelles effilochées, les bords coupants ou les dégâts avant et après le jeu."
