    "%lld" : {
      "comment" : "A numbered badge next to a text label, used to indicate a step in a process. The number is followed by a space and then the text label.",
      "isCommentAutoGenerated" : true
    },
    "1 louder peak" : {
      "extractionState" : "manual",
