      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qu’est-ce qui rend une caisse de transport moins stressante avant une visite vétérinaire ?"
          }
        }
      }
    },
    "When the carrier is familiar furniture instead of an alarm signal, calm practice becomes possible." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque la caisse devient un objet familier plutôt qu’un signal d’alarme, un entraînement calme devient possible."
          }
        }
      }
    },
    "Only bringing it out during emergencies" : {
