        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quel signe peut correspondre à un problème de puces même si vous n’en voyez aucune vivante ?"
          }
        }
      }
    },
    "Flea dirt and itching may be easier to notice than a moving flea. Ask a veterinary professional about safe cat-specific control." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les déjections de puces et les démangeaisons peuvent être plus faciles à repérer qu’une puce vivante. Demandez à un professionnel vétérinaire un traitement sûr pour les chats."
          }
        }
      }
    },
