      }
    },
    "Separate spaces and gradual scent exchange build familiarity before the pressure of direct contact." : {
      "extractionState" : "manual",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des espaces séparés et un échange progressif des odeurs créent de la familiarité avant la pression d’un contact direct."
